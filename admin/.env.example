# ============================================================
# Variables de entorno — admin/
# Copiar a .env y completar los valores.
# ============================================================

# --- Requeridas siempre (dev + prod) ---
BACKEND_SECRET_KEY=          # Clave secreta Flask (generar con: python -c "import secrets; print(secrets.token_hex(32))")
BACKEND_JWT_SECRET_KEY=      # Clave secreta JWT  (generar con: python -c "import secrets; print(secrets.token_hex(32))")

# --- Base de datos (desarrollo) ---
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grupo03
DB_SCHEME=postgresql+psycopg2

# --- Base de datos (producción — Render) ---
# DATABASE_URL=              # URL interna PostgreSQL provista por Render

# --- MinIO / S3 (desarrollo) ---
MINIO_SERVER_DEV=localhost:9000
MINIO_ACCESS_KEY_DEV=minioadmin
MINIO_SECRET_KEY_DEV=minioadmin
MINIO_SECURE_DEV=false
MINIO_BUCKET_NAME_DEV=grupo03

# --- MinIO / S3 (producción - Supabase) ---
# MINIO_SERVER=
# MINIO_ACCESS_KEY=
# MINIO_SECRET_KEY=


# --- Google OAuth ---
# GOOGLE_CLIENT_ID=          # Client ID de Google Cloud Console (requerido en producción)
